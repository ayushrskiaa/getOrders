generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts ConnectedAccount[]
  jobs     SyncJob[]
  orders   Order[]
}

model ConnectedAccount {
  id              String        @id @default(cuid())
  userId          String
  platform        String
  status          String        @default("CONNECTED")
  anakinSessionId String
  displayName     String?
  lastSyncedAt    DateTime?
  lastError       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs SyncJob[]

  @@unique([userId, platform])
}

model SyncJob {
  id          String     @id @default(cuid())
  userId      String
  accountId   String
  platform    String
  status      String     @default("PENDING")
  ordersFound Int        @default(0)
  recordingUrl String?
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime   @default(now())

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  account ConnectedAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Order {
  id             String   @id @default(cuid())
  userId         String
  platform       String
  externalOrderId String
  orderedAt      DateTime
  totalAmount    Decimal
  currency       String   @default("INR")
  status         String
  category       String   @default("OTHER")
  invoiceUrl     String?
  returnBy       DateTime?
  raw            String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    OrderItem[]
  invoices Invoice[]

  @@unique([userId, platform, externalOrderId])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  name        String
  quantity    Int      @default(1)
  unitPrice   Decimal
  category    String   @default("OTHER")
  productUrl  String?
  raw         String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Invoice {
  id        String   @id @default(cuid())
  orderId   String
  url       String
  label     String   @default("Invoice")
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ProductSnapshot {
  id          String   @id @default(cuid())
  platform    String
  productUrl  String
  title       String
  price       Decimal?
  rating      String?
  raw         String
  capturedAt  DateTime @default(now())
}
